# ==============================================================================
# Wajha Local Environment Variables Config Template
# Copy this file to a new file named '.env' in the same folder and fill in details.
# DO NOT commit the actual '.env' file to Git!
# ==============================================================================

# Django configuration
DEBUG=True
SECRET_KEY=django-insecure-change-this-to-a-secure-random-key-in-production

# Database Configuration (Set up local SQLite or MySQL connection)
# For local SQLite, leave DB_NAME empty or set to sqlite
DB_ENGINE=sqlite
DB_NAME=db.sqlite3

# MySQL settings (For staging / production or shared team DB)
# DB_ENGINE=mysql
# DB_NAME=wajha_db
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=127.0.0.1
# DB_PORT=3306

# AI Engine Credentials
ANTHROPIC_API_KEY=your_claude_api_key_here
